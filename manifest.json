{
  "manifest_version": 3,
  "name": "Fast Clicker",
  "description": "A minimal and efficient autoclicker for your browser. Activate it with a shortcut, place your cursor where you want, and let it handle the clicks for you.",
  "version": "1.0",
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "toggle-autoclicker": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle autoclicker"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}